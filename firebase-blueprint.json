{
  "entities": {
    "Generation": {
      "title": "Generation",
      "description": "An AI-generated media asset (image, video, or voice).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "voice"] },
        "prompt": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "userId", "type", "prompt", "url", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "credits": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/generations": {
      "schema": "Generation",
      "description": "History of AI generations for a specific user."
    },
    "/users/{userId}/profile": {
      "schema": "UserProfile",
      "description": "User profile and settings."
    }
  }
}
